FROM node:24-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Copy bundled fonts into dist so they're available when nest compiles on start
RUN mkdir -p dist/assets/fonts && cp src/assets/fonts/*.ttf dist/assets/fonts/

EXPOSE 3000

ENV NODE_OPTIONS="--expose-gc"

CMD ["npm", "run", "start:dev"]
