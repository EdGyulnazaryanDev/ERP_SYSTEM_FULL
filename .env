# ─── ERP System Configuration ────────────────────────────────
# Copy this file and adjust values for your environment.
# Docker Compose reads this automatically from the project root.

# ─── App Ports (host-side) ───────────────────────────────────
PORT_FRONTEND=8080          # Production frontend (nginx)
PORT_FRONTEND_DEV=5173      # Dev frontend (Vite)
PORT_BACKEND=3100           # Backend API

# ─── Database ────────────────────────────────────────────────
PORT_POSTGRES=5433
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_db

# ─── Redis ───────────────────────────────────────────────────
PORT_REDIS=6380

# ─── Kafka ───────────────────────────────────────────────────
PORT_KAFKA=9093

# ─── MinIO ───────────────────────────────────────────────────
PORT_MINIO_API=9100
PORT_MINIO_CONSOLE=9101
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_password
