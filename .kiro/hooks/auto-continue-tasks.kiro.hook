{
  "enabled": true,
  "name": "Auto Continue Tasks",
  "description": "After each agent session ends, checks TASKS.md for the next unchecked task and continues executing it automatically",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "Make tasks"
  },
  "workspaceFolderName": "ERP_SYSTEM_FULL",
  "shortName": "auto-continue-tasks"
}