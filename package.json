{
  "name": "erp-system",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "shared:build": "npm run build --workspace=packages/shared",
    "shared:watch": "npm run watch --workspace=packages/shared",
    "dev": "docker compose -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "prod": "docker compose up",
    "prod:build": "docker compose up --build",
    "test:all": "bash test-all.sh"
  }
}
